# ─── OTP / Email Settings ───────────────────────────────────────────────────
# Gmail example: SMTP_HOST=smtp.gmail.com  SMTP_PORT=587  SMTP_SECURE=false
#   (Use an App Password, not your real Gmail password)
# Zoho example:  SMTP_HOST=smtp.zoho.com   SMTP_PORT=587  SMTP_SECURE=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password-here
SMTP_FROM=FIBUCA <your-email@gmail.com>

# ─── WhatsApp OTP (CallMeBot – free) ────────────────────────────────────────
# 1. Add +34 644 55 22 68 on WhatsApp and send "I allow callmebot to send me messages"
# 2. You will receive your apikey in reply, paste it below
WHATSAPP_CALLMEBOT_APIKEY=your-callmebot-apikey-here

# ─── Dev / Testing ──────────────────────────────────────────────────────────
# Set to true to include the OTP code in the API response (remove in production!)
EXPOSE_DEV_OTP=false
