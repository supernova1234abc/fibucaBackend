generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("PRISMA_DATABASE_URL2_DATABASE_URL")
}

model User {
  id             Int       @id @default(autoincrement())
  name           String
  username       String    @unique
  email          String?
  profilePhotoUrl String?
  phone          String?
  phone2         String?
  password       String
  employeeNumber String    @unique
  role           Role      @default(CLIENT)
  firstLogin     Boolean   @default(true)
  otpCodeHash    String?
  otpPurpose     String?
  otpChannel     String?
  otpTarget      String?
  otpExpiresAt   DateTime?
  otpAttempts    Int       @default(0)
  otpVerifiedAt  DateTime?
  createdAt      DateTime  @default(now())
  deletedAt      DateTime?

  idCards     IdCard[]
  submissions Submission[]
  staffLinks  StaffLink[]
  staffMarked Submission[] @relation("StaffSubmissions")

  complaints       Complaint[]
  complaintReplies ComplaintReply[]
  transfers        TransferHistory[] @relation("TransferUser")
  transfersMade    TransferHistory[] @relation("TransferBy")
  publishedDocuments OfficialDocument[]
  publishedUpdates   OfficialUpdate[]
  votingSessions VotingSession[] @relation("VotingCreatedBy")
}


model StaffLink {
  id    Int    @id @default(autoincrement())
  token String @unique

  staffId Int
  staff   User @relation(fields: [staffId], references: [id], onDelete: Cascade)

  maxUses   Int?
  usedCount Int  @default(0)

  expiresAt DateTime
  isActive  Boolean  @default(true)

  createdAt DateTime @default(now())

  @@index([staffId])
}

model Submission {
  id             Int      @id @default(autoincrement())
  employeeName   String
  employeeNumber String   @unique
  phoneNumber    String? // ✅ NEW
  pdfPath        String?
  employerName   String
  branchName     String? // ✅ NEW (DB only, not printed on PDF)
  dues           String
  witness        String
  submittedAt    DateTime @default(now())
  deletedAt      DateTime? // Soft delete for submissions
  userDeletedAt  DateTime? // Tracks if associated user was deleted

  userId Int?
  user   User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  staffId Int?
  staff   User? @relation("StaffSubmissions", fields: [staffId], references: [id])

  @@index([userId])
  @@index([staffId])
  @@index([employerName])
  @@index([branchName])
  @@index([phoneNumber])
  @@index([employeeName])
  @@index([deletedAt])
  @@index([userDeletedAt])
}

model IdCard {
  id     Int  @id @default(autoincrement())
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId Int

  fullName      String
  rawPhotoUrl   String?
  cleanPhotoUrl String?
  company       String
  role          String
  issuedAt      DateTime @default(now())
  cardNumber    String   @unique
  verificationToken String @unique
  isActive      Boolean  @default(true)
  revokedAt     DateTime?
  expiresAt     DateTime?

  @@index([userId])
  @@index([verificationToken])
  @@index([isActive])
}

model Complaint {
  id        Int             @id @default(autoincrement())
  userId    Int
  subject   String
  message   String
  status    ComplaintStatus @default(OPEN)
  lastActivityAt DateTime   @default(now())
  clientLastReadAt DateTime?
  staffLastReadAt DateTime?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  user    User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  replies ComplaintReply[]

  @@index([userId])
  @@index([status])
  @@index([lastActivityAt])
}

model ComplaintReply {
  id          Int      @id @default(autoincrement())
  complaintId Int
  senderId    Int
  message     String
  createdAt   DateTime @default(now())

  complaint Complaint @relation(fields: [complaintId], references: [id], onDelete: Cascade)
  sender    User      @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([complaintId])
  @@index([senderId])
}

enum ComplaintStatus {
  OPEN
  RESOLVED
  CLOSED
}

model TransferHistory {
  id            Int @id @default(autoincrement())
  userId        Int
  performedById Int

  oldEmployerName String?
  newEmployerName String?
  oldBranchName   String? // ✅ NEW
  newBranchName   String? // ✅ NEW
  oldPhoneNumber  String? // ✅ NEW
  newPhoneNumber  String? // ✅ NEW

  oldEmployeeNumber String
  newEmployeeNumber String
  note              String?

  createdAt DateTime @default(now())

  user        User @relation("TransferUser", fields: [userId], references: [id], onDelete: Cascade)
  performedBy User @relation("TransferBy", fields: [performedById], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([performedById])
  @@index([newEmployerName])
  @@index([newBranchName])
}

enum Role {
  CLIENT
  ADMIN
  STAFF
  SUPERADMIN
}

model OfficialDocument {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  fileUrl     String
  createdAt   DateTime @default(now())

  createdById Int
  createdBy   User @relation(fields: [createdById], references: [id], onDelete: Cascade)

  @@index([createdById])
  @@index([createdAt])
}

model OfficialUpdate {
  id        Int      @id @default(autoincrement())
  title     String
  message   String
  category  String?
  createdAt DateTime @default(now())

  createdById Int
  createdBy   User @relation(fields: [createdById], references: [id], onDelete: Cascade)

  @@index([createdById])
  @@index([createdAt])
}

model UserAuditLog {
  id                   Int      @id @default(autoincrement())
  type                 String
  actorId              Int?
  actorName            String?
  actorRole            String?
  targetUserId         Int?
  targetName           String?
  targetUsername       String?
  targetEmployeeNumber String?
  targetRole           String?
  details              Json?
  ip                   String?
  createdAt            DateTime @default(now())

  @@index([type])
  @@index([actorId])
  @@index([targetUserId])
  @@index([createdAt])
}

model VotingSession {
  id          Int       @id @default(autoincrement())
  title       String
  position    String?
  description String?
  candidates  Json      // [{id: string, name: string, description?: string}]
  status      String    @default("PENDING") // PENDING | ACTIVE | ENDED
  genesisHash String
  createdById Int
  createdBy   User      @relation("VotingCreatedBy", fields: [createdById], references: [id])
  activatedAt DateTime?
  endedAt     DateTime?
  createdAt   DateTime  @default(now())
  votes       VoteRecord[]

  @@index([status])
  @@index([createdById])
}

model VoteRecord {
  id          Int      @id @default(autoincrement())
  sessionId   Int
  voterHash   String   // SHA256(userId:sessionId:VOTE_SECRET) — anonymous, verifiable
  positionKey String   @default("default")
  candidateId String
  blockIndex  Int
  prevHash    String
  blockHash   String   // SHA256(prevHash|voterHash|candidateId|createdAt.ISO)
  createdAt   DateTime @default(now())

  session VotingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, voterHash, positionKey])
  @@index([sessionId])
  @@index([positionKey])
  @@index([blockIndex])
}
